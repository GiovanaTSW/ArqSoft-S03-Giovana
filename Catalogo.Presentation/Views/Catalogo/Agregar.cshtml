@model CatalogoApp.Domain.Models.Item

@{
    ViewData["Title"] = "Agregar juego";
}

<a asp-action="Index" class="gv-back">← Cancelar</a>

<div style="margin-top:1.5rem;">
    <div class="gv-page-label">Nueva entrada</div>
    <h1>Agregar <span class="gv-cyan">Videojuego</span></h1>

    <form asp-action="Agregar" method="post" class="gv-form-wrap">
        <div class="gv-form-group">
            <label asp-for="Titulo" class="gv-label">Título</label>
            <input asp-for="Titulo" class="form-control" placeholder="Ej. The Legend of Zelda: BOTW" />
            <span asp-validation-for="Titulo" class="gv-red" style="font-size:0.78rem;"></span>
        </div>

        <div class="gv-form-group">
            <label asp-for="Genero" class="gv-label">Género</label>
            <input asp-for="Genero" class="form-control" placeholder="Ej. RPG, Acción, Aventura..." />
        </div>

        <div class="gv-form-group">
            <label asp-for="Consola" class="gv-label">Consola / Plataforma</label>
            <input asp-for="Consola" class="form-control" placeholder="Ej. Nintendo Switch, PS5, PC..." />
        </div>

        <div class="gv-form-group">
            <label asp-for="Ano" class="gv-label">Año de lanzamiento</label>
            <input asp-for="Ano" type="number" class="form-control" placeholder="@DateTime.Now.Year" />
        </div>

        <div class="gv-form-group">
            <label asp-for="Descripcion" class="gv-label">Descripción / Reseña</label>
            <textarea asp-for="Descripcion" class="form-control" rows="4"
                      placeholder="Tu opinión, sinopsis o notas sobre el juego..."></textarea>
        </div>

        <div style="margin-top:1.5rem; display:flex; gap:0.75rem;">
            <button type="submit" class="gv-btn-primary" style="padding:0.55rem 1.6rem;">
                Guardar →
            </button>
            <a asp-action="Index" class="gv-btn-secondary"
               style="padding:0.55rem 1.2rem; display:inline-block;">
                Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}